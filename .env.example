# Copy to .env locally, or add these keys in Render Dashboard → Environment
# Never commit .env (it contains secrets).

# Required for production
NODE_ENV=production
DATABASE_URL=postgresql://user:password@host:5432/dbname
SESSION_SECRET=your-long-random-secret-string

# Alpaca (market data)
ALPACA_API_KEY=
ALPACA_API_SECRET=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# OpenAI (Big Idea, Sentinel AI, synthesis, uploads, pattern-learning)
AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=
# OPENAI_API_KEY=

# Optional – fundamentals / scripts
# FMP_API_KEY=
# FINNHUB_API_KEY=
# TIINGO_API_KEY=

# PORT is set automatically by Render; omit or set for local dev (e.g. 5000)
